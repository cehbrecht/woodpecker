{
  "plans": [
    {
      "id": "atlas.atlas_basic",
      "local_id": "atlas_basic",
      "namespace": "atlas",
      "description": "Concrete ATLAS plan for atlas*.nc files",
      "links": [
        {
          "rel": "docs",
          "href": "https://cehbrecht.github.io/woodpecker/fixes.html#atlas.encoding_cleanup",
          "title": "ATLAS fix documentation"
        }
      ],
      "match": {
        "path_patterns": [
          "*atlas*.nc"
        ]
      },
      "fixes": [
        {
          "fix": "atlas.encoding_cleanup"
        },
        {
          "fix": "atlas.project_id_normalization"
        }
      ]
    }
  ]
}
