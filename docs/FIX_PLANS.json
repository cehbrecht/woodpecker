  {
    "id": "cmip7.esa_cci_water_vapour_dotname",
    "aliases": [],
    "description": "CMIP7/ESA CCI dot-name inputs",
    "match": {
      "attrs": {},
      "dataset_id_patterns": [],
      "path_patterns": [
        "esacci.WATERVAPOUR.*"
      ]
    },
    "steps": [
      {
        "id": "woodpecker.merge_equivalent_dimensions",
        "options": {
          "dims": [
            "bnds",
            "nv"
          ]
        },
        "links": []
      },
      {
        "id": "cmip7.configurable_reformat_bridge",
        "options": {
          "realm": "atmos",
          "branded_variable": "prw_tavg-u-hxy-u",
          "variable_map": {
            "prw": "tcwv"
          },
          "keep_global_attrs": true
        },
        "links": []
      },
      {
        "id": "woodpecker.ensure_latitude_is_increasing",
        "options": {},
        "links": []
      }
    ],
    "links": [
      {
        "rel": "self",
        "href": "https://github.com/cehbrecht/woodpecker/blob/main/plugins/woodpecker-cmip7-plugin/src/woodpecker_cmip7_plugin/plans/esa_cci_water_vapour_plan.json",
        "title": "Source plan document"
      }
    ],
    "prefix": "cmip7",
    "suffix": "esa_cci_water_vapour_dotname",
    "source": "plugin:woodpecker_cmip7_plugin",
    "source_files": [
      "plugins/woodpecker-cmip7-plugin/src/woodpecker_cmip7_plugin/plans/esa_cci_water_vapour_plan.json"
    ],
    "step_ids": [
      "woodpecker.merge_equivalent_dimensions",
      "cmip7.configurable_reformat_bridge",
      "woodpecker.ensure_latitude_is_increasing"
    ]
  },
