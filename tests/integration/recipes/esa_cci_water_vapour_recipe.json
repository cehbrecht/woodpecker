{
  "schema_version": 1,
  "recipes": [
    {
      "id": "cmip7.esa_cci_water_vapour_zarr",
      "description": "CMIP7/ESA CCI zarr-style inputs",
      "links": [
        {
          "rel": "self",
          "href": "https://github.com/cehbrecht/woodpecker/blob/main/tests/integration/recipes/esa_cci_water_vapour_recipe.json",
          "title": "Source recipe document"
        },
        {
          "rel": "issue",
          "href": "https://github.com/cehbrecht/woodpecker/issues",
          "title": "Track ESA CCI fix discussions"
        }
      ],
      "match": {
        "path_patterns": [
          "*ESACCI-WATERVAPOUR-*.zarr"
        ]
      },
      "steps": [
        {
          "id": "cmip7.configurable_reformat_bridge",
          "options": {
            "realm": "atmos",
            "branded_variable": "prw_tavg-u-hxy-u",
            "dim_map": {
              "bnds": "nv"
            },
            "variable_map": {
              "prw": "tcwv"
            },
            "keep_global_attrs": true
          }
        },
        {
          "id": "woodpecker.ensure_latitude_is_increasing"
        }
      ]
    },
    {
      "id": "cmip7.esa_cci_water_vapour_dotname",
      "description": "CMIP7/ESA CCI dot-name inputs",
      "links": [
        {
          "rel": "self",
          "href": "https://github.com/cehbrecht/woodpecker/blob/main/tests/integration/recipes/esa_cci_water_vapour_recipe.json",
          "title": "Source recipe document"
        }
      ],
      "match": {
        "path_patterns": [
          "esacci.WATERVAPOUR.*"
        ]
      },
      "steps": [
        {
          "id": "woodpecker.merge_equivalent_dimensions",
          "options": {
            "dims": [
              "bnds",
              "nv"
            ]
          }
        },
        {
          "id": "cmip7.configurable_reformat_bridge",
          "options": {
            "realm": "atmos",
            "branded_variable": "prw_tavg-u-hxy-u",
            "variable_map": {
              "prw": "tcwv"
            },
            "keep_global_attrs": true
          }
        },
        {
          "id": "woodpecker.ensure_latitude_is_increasing"
        }
      ]
    }
  ]
}
